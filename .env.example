# Copy this file to .env (no extension after the dot) and fill in real values.
# .env is gitignored — never commit it.

# Anthropic API — for Claude calls (next-hop selection, type classification).
# Get one at https://console.anthropic.com → API keys.
ANTHROPIC_API_KEY=

# Supabase — Project Settings → API in the Supabase dashboard.
# For Field Trips' existing project, SUPABASE_URL is already known (below).
# SUPABASE_SERVICE_ROLE_KEY has full DB access — keep it secret, server-side only.
SUPABASE_URL=https://vjikcsifkvphuiwjrmqi.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Postgres schema where path-finder tables live. Don't change unless you've migrated.
DB_SCHEMA=path_finder

# Defaults (override as needed)
MAX_HOPS=10
DEFAULT_PERMUTATIONS=3
CLAUDE_MODEL=claude-sonnet-4-6
